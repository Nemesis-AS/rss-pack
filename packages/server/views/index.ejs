<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>rss reader</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="container">
    <header>
      <h1>rss reader</h1>
      <nav class="tabs">
        <button class="tab-btn active" data-tab="articles">articles</button>
        <button class="tab-btn" data-tab="feeds">feeds</button>
      </nav>
    </header>

    <section id="articles-view" class="view">
      <div class="toolbar">
        <input type="search" id="search-input" placeholder="search articles..." />
        <select id="feed-filter">
          <option value="">all feeds</option>
        </select>
        <div class="toggle-group">
          <button class="toggle-btn active" data-filter="all">all</button>
          <button class="toggle-btn" data-filter="starred">starred</button>
        </div>
      </div>
      <ul id="article-list" class="article-list"></ul>
      <div class="pagination">
        <button id="prev-page">&larr; prev</button>
        <span id="page-info"></span>
        <button id="next-page">next &rarr;</button>
      </div>
    </section>

    <section id="feeds-view" class="view hidden">
      <form id="add-feed-form" class="add-feed-form">
        <input type="url" id="feed-url-input" placeholder="https://example.com/feed.xml" required />
        <button type="submit">add</button>
      </form>
      <div id="feed-error" class="error hidden"></div>
      <ul id="feed-list" class="feed-list"></ul>
    </section>
  </div>

  <div id="article-modal" class="modal hidden">
    <div class="modal-content">
      <button id="modal-close" class="close-btn" aria-label="close">&times;</button>
      <h2 id="modal-title"></h2>
      <div id="modal-meta" class="modal-meta"></div>
      <div id="modal-body" class="modal-body"></div>
      <div class="modal-actions">
        <a id="modal-link" href="#" target="_blank" rel="noopener noreferrer">open original &rarr;</a>
        <button id="modal-star">star</button>
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
